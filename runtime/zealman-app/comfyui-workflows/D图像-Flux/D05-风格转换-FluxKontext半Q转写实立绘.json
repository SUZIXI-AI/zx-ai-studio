ble mood. While precisely preserving these core design features: long black hair with pink streaks, red eyes, cat-like ears with red tips, and a tail ending in a red-tipped mechanical hook."],"color":"#2a363b","bgcolor":"#3f5159"},{"id":1221,"type":"VAEEncode","pos":[-3291.006756891364,502.72429845081984],"size":[238.64869689941406,50],"flags":{"collapsed":true},"order":9,"mode":0,"inputs":[{"label":"pixels","localized_name":"像素","name":"pixels","type":"IMAGE","link":6278},{"label":"vae","localized_name":"vae","name":"vae","type":"VAE","link":6280}],"outputs":[{"label":"LATENT","localized_name":"Latent","name":"LATENT","type":"LATENT","links":[6345]}],"properties":{"cnr_id":"comfy-core","ver":"0.3.39","Node name for S&R":"VAEEncode","enableTabs":false,"tabWidth":65,"tabXOffset":10,"hasSecondTab":false,"secondTabText":"Send Back","secondTabOffset":80,"secondTabWidth":65,"ue_properties":{"version":"7.0.1","widget_ue_connectable":{}}},"widgets_values":[],"shape":1},{"id":1258,"type":"FluxGuidance","pos":[-4053.9216775001823,383.86094770787054],"size":[276.49124396307207,118.43862281383838],"flags":{"collapsed":false},"order":14,"mode":0,"inputs":[{"label":"conditioning","localized_name":"条件","name":"conditioning","type":"CONDITIONING","link":6351},{"label":"guidance","localized_name":"引导","name":"guidance","type":"FLOAT","widget":{"name":"guidance"},"link":null}],"outputs":[{"label":"CONDITIONING","localized_name":"条件","name":"CONDITIONING","type":"CONDITIONING","slot_index":0,"links":[6341]}],"properties":{"cnr_id":"comfy-core","ver":"0.3.38","Node name for S&R":"FluxGuidance","enableTabs":false,"tabWidth":65,"tabXOffset":10,"hasSecondTab":false,"secondTabText":"Send Back","secondTabOffset":80,"secondTabWidth":65,"ue_properties":{"version":"7.0.1","widget_ue_connectable":{}}},"widgets_values":[4],"shape":1},{"id":732,"type":"CheckpointLoaderSimple","pos":[-4054.678466796875,131.40734966486164],"size":[739.0740913863078,212.03513738460072],"flags":{"collapsed":false},"