ets_values":["Z-Image-Turbo-Fun-Controlnet-Union-2.1.safetensors"]},{"id":22,"type":"ShowText|pysssss","pos":[-946.9754603382644,-271.9265468417052],"size":[429.4522705078125,657.3260498046875],"flags":{},"order":15,"mode":0,"inputs":[{"label":"text","localized_name":"text","name":"text","type":"STRING","link":167}],"outputs":[{"label":"text","localized_name":"字符串","name":"STRING","shape":6,"type":"STRING","links":[157,159]}],"properties":{"cnr_id":"comfyui-custom-scripts","ver":"f2838ed5e59de4d73cde5c98354b87a8d3200190","Node name for S&R":"ShowText|pysssss","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.4.1"},"widget_ue_connectable":{}},"widgets_values":["一位身着素雅汉服的年轻女子，半身特写，衣袂飘然，发丝如瀑，几缕轻扬于风中，发髻高挽，缀以精致银饰与白花，耳垂悬挂水滴形玉坠，温润如玉。她面容清丽，眉目含情，唇色淡红，目光柔和而深邃，似有千言万语藏于眸底。女子静立，微微侧首，姿态温婉，似在凝望远方，又似在与风对话，衣襟轻拂，似有微风拂面。\n\n前景为女子纤细的手臂与衣袖边缘，衣料轻薄如纱，纹理细腻，边缘绣有暗纹，随风轻摆，增添灵动之感。中景为女子躯干与上衣主体，衣襟交叠处露出内衬，腰间束带，纹样繁复而典雅，与外袍形成层次之美。背景为朦胧水雾弥漫的山林或湖畔，青绿与灰蓝交织，雾气氤氲，似晨曦初露或暮色将至，光影在雾中若隐若现，营造出空灵静谧的氛围。\n\n构图采用中心对称式，人物居中，视线自然聚焦于面部，背景虚化处理，强化主体突出。视觉引导从女子发丝的飘动延伸至衣袖，再至背景雾气，形成柔和的流动感。光影柔和，主光源来自左上方，光线如薄纱般洒落于面庞与衣襟，勾勒出细腻的轮廓，阴影部分则融入背景雾气，形成自然过渡，不显生硬。\n\n整体氛围静谧而诗意，如古画中走出的仙子，带着古典韵味与现代审美融合的美感。画面似由专业摄影设备拍摄，但细节处理细腻如AI生成，光影过渡自然，色彩饱和度适中，保留了真实感的同时又不失艺术渲染。此图适合用于古风摄影、虚拟角色设定或文化宣传，传达出东方美学的柔美与深邃。"],"color":"#223","bgcolor":"#335"},{"id":116,"type":"easy cleanGpuUsed","pos":[-482.52149913909284,-194.6047329258686],"size":[140,26],"flags":{},"order":17,"mode":0,"inputs":[{"label":"输入任何","localized_name":"输入任何","name":"anything","type":"*","link":157}],"outputs":[{"localized_name":"output","name":"output","type":"*","links":null}],"properties":{"cnr_id":"comfyui-easy-use","ver":"640ef31625e18f72becea245a778fcbb13c457ee","Node name for S&R":"easy cleanGpuUsed","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.3"}},"widgets_values":[]},{"id":16,"type":"Qwen3_VQA","pos":[-1834.9058088933725,-270.7754749533906],"size":[217.015625,598.8773193359375],"flags":{},"order":11,"mo